<?xml version="1.0" standalone="yes"?>
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
    <channel>
        <title>Finder Toolbox</title>
        <link>https://raw.githubusercontent.com/derx05/Finder-Toolbox/main/appcast.xml</link>
        <description>Finder Toolbox release feed.</description>
        <language>en</language>

        <!--
            Channel convention (kept in sync with `UpdateChannel` in the app):

              - Release builds          : no <sparkle:channel> element.
              - Beta builds             : <sparkle:channel>beta</sparkle:channel>
              - Development builds      : <sparkle:channel>development</sparkle:channel>

            Versioning convention:
              - sparkle:version         : YYYY.MM.DD.NN  (build number, dots only — Sparkle stops at first dash)
              - sparkle:shortVersionString : Major.Minor.Patch[-prerelease.N]
                  e.g. "0.1.0-beta.1", "0.1.0-dev.1", "0.2.0"

            Release artifact naming:
              - File : FinderToolbox-{marketing-version}-{build-number}.zip
                  e.g. FinderToolbox-0.1.0-beta.1-2026.05.28.01.zip
              - Tag  : v{marketing-version}
                  e.g. v0.1.0-beta.1
              - Title: Finder Toolbox {marketing-version} ({build-number})
                  e.g. Finder Toolbox 0.1.0-beta.1 (2026.05.28.01)

            See docs/RELEASING.md for the full release procedure.
        -->

    </channel>
</rss>
